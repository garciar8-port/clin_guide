# ClinGuide environment variables
# Copy to .env and fill in your keys

# --- API Keys ---
CLINGUIDE_ANTHROPIC_API_KEY=
CLINGUIDE_OPENAI_API_KEY=
CLINGUIDE_COHERE_API_KEY=
CLINGUIDE_PINECONE_API_KEY=

# --- Pinecone ---
CLINGUIDE_PINECONE_INDEX=clinguide
CLINGUIDE_PINECONE_CLOUD=aws
CLINGUIDE_PINECONE_REGION=us-east-1

# --- Server ---
CLINGUIDE_HOST=0.0.0.0
CLINGUIDE_PORT=8000
CLINGUIDE_DEBUG=false
